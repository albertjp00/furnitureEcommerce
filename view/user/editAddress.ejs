        <script>
document.addEventListener("DOMContentLoaded", function () {
    const form = document.getElementById('editAddressForm');

    if (!form) return;

    form.addEventListener('submit', function(event) {

        const houseAddressInput = document.getElementById('addaddress-textarea');
        const countryInput = document.getElementById('state');
        const pincodeInput = document.getElementById('pincode');
        const placeInput = document.getElementById('place');

        const houseAddress = houseAddressInput.value.trim();
        const country = countryInput.value.trim();
        const pincode = pincodeInput.value.trim();
        const place = placeInput.value.trim();

        houseAddressInput.value = houseAddress;
        countryInput.value = country;
        pincodeInput.value = pincode;
        placeInput.value = place;

        const toastEl = document.getElementById("liveToast");
        const toastMsg = document.getElementById("toastMessage");
        const toast = new bootstrap.Toast(toastEl);

        toastEl.classList.remove("text-bg-danger", "text-bg-success");

        if (!houseAddress || !country || !pincode || !place) {
            toastMsg.innerText = "Please fill in all fields.";
            toastEl.classList.add("text-bg-danger");
            toast.show();
            event.preventDefault();
            return;
        }

        if (!/^\d{6}$/.test(pincode)) {
            toastMsg.innerText = "Invalid pincode.";
            toastEl.classList.add("text-bg-danger");
            toast.show();
            event.preventDefault();
            return;
        }
    });
});







</script>


